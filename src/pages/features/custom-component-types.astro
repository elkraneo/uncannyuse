---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import typeData from "../../data/features/custom-component-types.json";

type TypeEntry = { swift: string; usd: string; supported: boolean | null; note?: string };
type TypeGroup = { id: string; name: string; description: string; types: TypeEntry[] };

const allTypes = typeData.groups.flatMap((g) => g.types);
const supportedCount = allTypes.filter((t) => t.supported === true).length;
const unsupportedCount = allTypes.filter((t) => t.supported === false).length;
const untestedCount = allTypes.filter((t) => t.supported === null).length;
const totalTypes = allTypes.length;

const color = "#30D158";

// Resource preview fetching (mirrors [slug].astro)
type ResourceEntry = {
	title?: string;
	url: string;
	type: string;
	source: string;
	verifiedAt?: string;
	description?: string;
	image?: string;
};

type ResourcePreview = ResourceEntry & {
	previewTitle: string;
	previewDescription?: string;
	previewImage?: string;
	domain: string;
};

const resourcePreviewCache = new Map<string, Promise<ResourcePreview>>();

function decodeHtmlEntities(value: string): string {
	return value
		.replace(/&amp;/g, "&")
		.replace(/&quot;/g, '"')
		.replace(/&#39;/g, "'")
		.replace(/&lt;/g, "<")
		.replace(/&gt;/g, ">");
}

function stripHtml(value: string): string {
	return decodeHtmlEntities(
		value
			.replace(/<[^>]*>/g, " ")
			.replace(/\s+/g, " ")
			.trim(),
	);
}

function getMetaContent(html: string, key: string): string | undefined {
	const escapedKey = key.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
	const patterns = [
		new RegExp(
			`<meta[^>]+(?:property|name)=["']${escapedKey}["'][^>]*content=["']([^"']+)["'][^>]*>`,
			"i",
		),
		new RegExp(
			`<meta[^>]+content=["']([^"']+)["'][^>]*(?:property|name)=["']${escapedKey}["'][^>]*>`,
			"i",
		),
	];
	for (const pattern of patterns) {
		const match = html.match(pattern);
		if (match?.[1]) return stripHtml(match[1]);
	}
	return undefined;
}

function getHtmlTitle(html: string): string | undefined {
	const match = html.match(/<title[^>]*>([^<]+)<\/title>/i);
	return match?.[1] ? stripHtml(match[1]) : undefined;
}

function getDomain(url: string): string {
	try {
		return new URL(url).hostname.replace(/^www\./, "");
	} catch {
		return url;
	}
}

function initialsFromDomain(domain: string): string {
	return domain
		.split(".")
		.filter(Boolean)
		.slice(0, 2)
		.map((part) => part[0]?.toUpperCase() ?? "")
		.join("");
}

async function fetchResourcePreview(
	resource: ResourceEntry,
): Promise<ResourcePreview> {
	const cached = resourcePreviewCache.get(resource.url);
	if (cached) return cached;

	const fallback: ResourcePreview = {
		...resource,
		previewTitle: resource.title ?? resource.url,
		previewDescription: resource.description,
		previewImage: resource.image,
		domain: getDomain(resource.url),
	};

	const request = (async () => {
		try {
			const response = await fetch(resource.url, {
				redirect: "follow",
				headers: {
					"User-Agent": "Mozilla/5.0 (compatible; uncannyuse-link-preview/1.0)",
				},
				signal: AbortSignal.timeout(3500),
			});
			if (!response.ok) return fallback;
			const contentType = response.headers.get("content-type") ?? "";
			if (!contentType.includes("text/html")) return fallback;
			const html = (await response.text()).slice(0, 250_000);

			const ogTitle =
				getMetaContent(html, "og:title") ??
				getMetaContent(html, "twitter:title") ??
				getHtmlTitle(html) ??
				resource.url;
			const ogDescription =
				resource.description ??
				getMetaContent(html, "og:description") ??
				getMetaContent(html, "twitter:description") ??
				getMetaContent(html, "description");

			const rawImage =
				resource.image ??
				getMetaContent(html, "og:image") ??
				getMetaContent(html, "twitter:image");
			let ogImage = rawImage;
			if (rawImage) {
				try {
					ogImage = new URL(rawImage, resource.url).toString();
				} catch {
					ogImage = undefined;
				}
			}

			return {
				...resource,
				previewTitle: resource.title ?? ogTitle,
				previewDescription: ogDescription,
				previewImage: ogImage,
				domain: getDomain(resource.url),
			};
		} catch {
			return fallback;
		}
	})();

	resourcePreviewCache.set(resource.url, request);
	return request;
}

const resourcesEntry = (await getCollection("resources")).find(
	(r) => r.data.componentId === "custom-component-types",
);
const resourcesList: ResourceEntry[] = [
	{
		url: "https://openusd.org/release/api/sdf_page_front.html#sdf_metadata_types",
		type: "official-docs",
		source: "Apple",
		title: "OpenUSD SdfValueTypeNames",
	},
	{
		url: "https://developer.apple.com/documentation/realitykit/component",
		type: "official-docs",
		source: "Apple",
		title: "Apple Developer Documentation — Component",
	},
	...(resourcesEntry?.data.resources ?? []),
];

const resourcesWithPreview = await Promise.all(
	resourcesList.map((resource) => fetchResourcePreview(resource)),
);

function rowClass(t: TypeEntry): string {
	if (t.supported === false) return "row-unsupported";
	if (t.supported === null) return "row-untested";
	return "";
}

function escapeHtml(value: string): string {
	return value
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;");
}

function highlightUsda(source: string): string {
	let html = escapeHtml(source);
	const placeholders: string[] = [];

	function stash(pattern: RegExp, className: string) {
		html = html.replace(pattern, (match) => {
			const idx = placeholders.push(`<span class="${className}">${match}</span>`) - 1;
			return `@@TOKEN_${idx}@@`;
		});
	}

	// Protect strings and comments first so later passes don't style inside them.
	stash(/"([^"\\]|\\.)*"/g, "usda-string");
	stash(/#[^\n]*/g, "usda-comment");

	html = html
		.replace(
			/\b(def|uniform|rel|prepend|token|bool|string|double|float|float2|float3|float4|int|uint)\b/g,
			'<span class="usda-key">$1</span>',
		)
		.replace(
			/\b(RealityKitComponent|RealityKitDict|RealityKit[A-Za-z0-9_]+)\b/g,
			'<span class="usda-type">$1</span>',
		)
		.replace(/\b(-?\d+(?:\.\d+)?)\b/g, '<span class="usda-number">$1</span>');

	html = html.replace(/@@TOKEN_(\d+)@@/g, (_, n) => placeholders[Number(n)] ?? "");
	return html;
}

function badgeHtml(t: TypeEntry): string {
	if (t.supported === true) {
		return `<span class="badge badge-supported" aria-label="supported">✓</span>`;
	}
	if (t.supported === false) {
		return `<span class="badge badge-unsupported" aria-label="unsupported">✗</span>`;
	}
	return `<span class="badge badge-untested" aria-label="not tested">?</span>`;
}

function noteHtml(t: TypeEntry): string {
	if (!t.note) return "";
	return `<span class="badge-note">${t.note}</span>`;
}

const componentClaims = (await getCollection("rcp-claims"))
	.filter((entry) => entry.data.componentId === "custom-component-types")
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

type ComponentNote =
	| {
			kind: "development-note";
			axis: "rcp" | "runtime" | "general";
			text: string;
			summary: string;
			author: string;
			date: string;
			link: string;
	  }
	| {
			kind: "system";
			axis: "rcp";
			text: string;
			summary: string;
			author: string;
			date: string;
	  };

const unifiedNotes: ComponentNote[] = [
	{
		kind: "system",
		axis: "rcp",
		text: "Custom component field data does not appear as USD attributes",
		summary: "The USDA file only contains the component scaffold with info:id. Field data is serialized in the Swift/Xcode build pipeline, not the USD authoring layer.",
		author: "system",
		date: "current",
	},
];

for (const claim of componentClaims) {
	unifiedNotes.push({
		kind: "development-note",
		axis: claim.data.axis,
		text: claim.data.claim,
		summary: claim.data.summary,
		author: claim.data.author,
		date: claim.data.date.toISOString().slice(0, 10),
		link: `/research/${claim.slug}/`,
	});
}

const docsUrl = "https://developer.apple.com/documentation/realitykit/component";
---

<Base title="Custom Component" description={typeData.description}>
	<article class="detail">
		<!-- Breadcrumb -->
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/" class="bc-link">realitykit</a>
			<span class="bc-sep">/</span>
			<a href="/?cat=custom" class="bc-cat" style={`color: ${color}`}>custom</a>
			<span class="bc-sep">/</span>
			<span class="bc-current">custom component</span>
		</nav>

		<!-- Header -->
		<header class="detail-header">
			<div class="header-meta">
			<span class="cat-tag" style={`color: ${color}; border-color: ${color}33`}>
				Custom
			</span>
				<span class="rcp-tag">✓ RCP</span>
			</div>

			<h1 class="detail-title">Custom Component</h1>
			<div class="detail-links">
				<a
					class="doc-chip"
					href={docsUrl}
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="doc-chip-label">documentation</span>
					<span class="doc-external" aria-hidden="true">↗</span>
				</a>
			</div>
			<p class="detail-desc">
				Swift field type support for custom components is determined by Reality Composer Pro's
				codegen and Xcode validation pipeline. Types are tested by compiling fixtures in RCP and
				inspecting which fields survive the build process.
			</p>
		</header>

		<!-- Type coverage stats -->
		<section class="section">
			<h2 class="section-label">/// type coverage</h2>
			<div class="stats-row">
				<div class="stat">
					<span class="stat-num" style="color: var(--text)">{totalTypes}</span>
					<span class="stat-label">types tested</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num" style="color: var(--rcp)">{supportedCount}</span>
					<span class="stat-label">supported</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num" style="color: var(--macos)">{unsupportedCount}</span>
					<span class="stat-label">unsupported</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num" style="color: var(--muted)">{untestedCount}</span>
					<span class="stat-label">untested</span>
				</div>
			</div>
		</section>

		<!-- RCP authored schema — type matrix -->
		<section class="section schema-intro">
			<h2 class="section-label">/// rcp authored schema</h2>
			<p class="schema-intro-copy">
				Type support matrix for custom component fields in Reality Composer Pro.
				Each Swift type was compiled in an RCP test fixture and inspected for field survival.
			</p>
		</section>

		{typeData.groups.map((group: TypeGroup) => (
			<section class="section">
				<h2 class="section-label">/// {group.name.toLowerCase()}</h2>
				<p class="group-desc">{group.description}</p>
				<div class="type-table-wrap">
					<table class="type-table">
						<thead>
							<tr>
								<th>Swift Type</th>
								<th>OpenUSD Type</th>
								<th>RCP Support</th>
							</tr>
						</thead>
						<tbody>
							{group.types.map((t: TypeEntry) => (
								<tr class={rowClass(t)}>
									<td><code>{t.swift}</code></td>
									<td><code class="usd-type">{t.usd}</code></td>
									<td>
										<Fragment set:html={badgeHtml(t) + " " + noteHtml(t)} />
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>
		))}

		<!-- Source Reference -->
		<section class="section">
			<h2 class="section-label">/// usda scaffold</h2>
			<div class="source-block">
				<div class="code-shell">
					<div class="code-head">
						<span class="code-lang">USDA</span>
					</div>
					<pre><code set:html={highlightUsda('def RealityKitCustomComponent "ModuleName_ComponentName" (\n    active = true\n)\n{\n    uniform token info:id = "ModuleName.ComponentName"\n}')} /></pre>
				</div>
				<p class="source-note">
					A custom component with an <code>Int</code> field produces this USDA —
					zero field attributes beyond <code>info:id</code>. The field data is serialized
					elsewhere in the build pipeline.
				</p>
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<!-- Notes & Resources -->
		<section class="section">
			<div class="section-head">
				<h2 class="section-label">/// notes & resources</h2>
				<div class="claim-actions">
					<a href="/research/" class="claim-action-link">browse all notes</a>
				</div>
			</div>

			<ul class="claim-list">
				{unifiedNotes.map((note) => (
					<li class="claim-item">
						<p class="claim-text">{note.text}</p>
						{note.summary && (
							<p class="claim-summary">{note.summary}</p>
						)}
						<p class="claim-byline">
							<span class:list={[
								"note-tag",
								note.axis === "rcp" ? "note-tag-rcp" : "note-tag-general",
							]}>
								{note.axis === "rcp" ? "RCP" : note.axis === "runtime" ? "runtime" : "general"}
							</span>{" "}
							by {note.author} · {note.date}
						</p>
						{"link" in note && note.link && (
							<a class="claim-link" href={note.link}>
								details →
							</a>
						)}
					</li>
				))}
			</ul>

			<ul class="resource-list">
				{resourcesWithPreview.map((resource) => (
					<li class="resource-item">
						<a
							href={resource.url}
							target="_blank"
							rel="noopener noreferrer"
							class="resource-link"
						>
							<span class="resource-preview-media" aria-hidden="true">
								{resource.previewImage ? (
									<img
										src={resource.previewImage}
										alt=""
										class="resource-preview-image"
										loading="lazy"
										decoding="async"
										referrerpolicy="no-referrer"
									/>
								) : (
									<span class="resource-preview-fallback">
										{initialsFromDomain(resource.domain)}
									</span>
								)}
							</span>
							<span class="resource-preview-body">
								<span class="resource-preview-title">
									{resource.previewTitle}
								</span>
								{resource.previewDescription && (
									<span class="resource-preview-description">
										{resource.previewDescription}
									</span>
								)}
								<span class="resource-meta">
									{resource.domain}
									{" · "}
									{resource.source}
								</span>
							</span>
							<span class="resource-preview-external" aria-hidden="true">↗</span>
						</a>
					</li>
				))}
			</ul>
		</section>

		<!-- Footer nav -->
		<div class="detail-footer">
			<div class="detail-actions">
				<a href="/" class="back-link">
					<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
						<path d="M7.5 2L3 6l4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
					all components
				</a>
			</div>
		</div>
	</article>
</Base>

<style>
	.detail {
		max-width: 760px;
		margin: 0 auto;
		padding: 2rem 1.5rem 5rem;
		animation: fadeIn 0.2s ease-out;
	}

	/* Breadcrumb */
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		margin-bottom: 2rem;
		overflow: hidden;
	}

	.bc-link {
		color: var(--muted);
		text-decoration: none;
	}

	.bc-link:hover {
		color: var(--text);
	}

	.bc-sep {
		color: var(--subtle);
	}

	.bc-cat {
		text-transform: lowercase;
		text-decoration: none;
	}

	.bc-cat:hover {
		text-decoration: underline;
	}

	.bc-current {
		color: var(--text);
		font-weight: 500;
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	/* Header */
	.detail-header {
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border);
	}

	.header-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}

	.cat-tag {
		font-size: 0.875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border: 1px solid;
		padding: 2px 7px;
		border-radius: 3px;
	}

	.rcp-tag {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--rcp);
		background: rgba(48, 209, 88, 0.08);
		border: 1px solid rgba(48, 209, 88, 0.2);
		padding: 2px 7px;
		border-radius: 3px;
	}

	.detail-title {
		font-size: clamp(1.5rem, 3.5vw, 2rem);
		font-weight: 500;
		letter-spacing: -0.02em;
		color: var(--text);
		line-height: 1.15;
		margin-bottom: 0.875rem;
		overflow-wrap: break-word;
		word-break: break-word;
	}

	.detail-links {
		margin-bottom: 0.75rem;
	}

	.doc-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.875rem;
		font-weight: 400;
		color: var(--ios);
		text-decoration: none;
		padding: 0;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.doc-chip:hover {
		color: #005ec9;
	}

	.doc-chip-label {
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.doc-external {
		font-size: 0.75em;
		line-height: 1;
		opacity: 0.9;
	}

	.detail-desc {
		font-size: 1.0625rem;
		color: var(--muted);
		line-height: 1.7;
		max-width: 60ch;
	}

	/* Section */
	.section {
		margin-bottom: 2rem;
	}

	.section-divider {
		height: 1px;
		background: var(--border);
		margin: 0 0 2rem 0;
	}

	.section-label {
		font-size: 0.875rem;
		font-weight: 400;
		color: var(--muted);
		letter-spacing: 0.04em;
		margin-bottom: 1rem;
	}

	.section-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-bottom: 0.55rem;
	}

	/* Stats */
	.stats-row {
		display: flex;
		align-items: center;
		gap: 0;
		flex-wrap: wrap;
		row-gap: 0.75rem;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding-right: 1.5rem;
	}

	.stat-num {
		font-size: 1.6923rem;
		font-weight: 500;
		letter-spacing: -0.025em;
		line-height: 1;
		font-variant-numeric: tabular-nums;
	}

	.stat-label {
		font-size: 0.6923rem;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.stat-divider {
		width: 1px;
		height: 2rem;
		background: var(--border);
		margin-right: 1.5rem;
		flex-shrink: 0;
	}

	/* Schema intro */
	.schema-intro {
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(circle at top right, rgba(0, 122, 255, 0.16), transparent 34%),
			radial-gradient(circle at bottom left, rgba(48, 209, 88, 0.12), transparent 30%),
			linear-gradient(180deg, color-mix(in srgb, var(--surface-top) 72%, black) 0%, var(--surface) 100%);
		border: 1px solid color-mix(in srgb, var(--border-up) 78%, rgba(142, 208, 192, 0.28));
		border-radius: 16px;
		padding: 1.35rem 1.5rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.04),
			0 18px 40px rgba(0, 0, 0, 0.28);
	}

	.schema-intro .section-label {
		margin-bottom: 0.35rem;
	}

	.schema-intro-copy {
		margin: 0;
		font-size: 0.96rem;
		color: var(--muted);
		line-height: 1.55;
		max-width: 42rem;
	}

	@media (prefers-color-scheme: light) {
		.schema-intro {
			background:
				radial-gradient(circle at top right, rgba(0, 85, 204, 0.12), transparent 34%),
				radial-gradient(circle at bottom left, rgba(22, 106, 47, 0.1), transparent 30%),
				linear-gradient(120deg, #fbfffd 0%, #f3f7ff 100%);
			border-color: color-mix(in srgb, var(--border-up) 78%, rgba(22, 106, 47, 0.2));
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.75),
				0 16px 32px rgba(29, 29, 31, 0.08);
		}
	}

	@media (max-width: 640px) {
		.schema-intro {
			padding: 1.15rem 1rem;
			border-radius: 14px;
		}
	}

	/* Group description */
	.group-desc {
		font-size: 0.9rem;
		color: var(--muted);
		line-height: 1.55;
		margin-bottom: 0.75rem;
	}

	/* Type table */
	.type-table-wrap {
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
		background: var(--surface);
	}

	.type-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
	}

	.type-table th,
