---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { getAllFeatures } from "../../lib/components";

export async function getStaticPaths() {
	const claims = await getCollection("rcp-claims");
	return claims.map((claim) => ({
		params: { slug: claim.slug },
		props: { claim },
	}));
}

const { claim } = Astro.props;
const { Content } = await render(claim);

const features = await getAllFeatures();
const featureNames = new Map(features.map((f) => [f.id, f.name]));
featureNames.set("custom-component-types", "Custom Component");
const componentName = featureNames.get(claim.data.componentId) ?? claim.data.componentId;

function formatDate(date: Date): string {
	return date.toISOString().slice(0, 10);
}

function isAbsoluteLocalPath(path: string): boolean {
	return (
		path.startsWith("/") ||
		/^[a-zA-Z]:[\\/]/.test(path) ||
		path.startsWith("\\\\") ||
		path.startsWith("file://")
	);
}
---

<Base
	title={`${componentName}: ${claim.data.claim}`}
	description={claim.data.summary}
>
	<article class="claim-page">
		<nav class="claim-breadcrumb">
			<a href={`/features/${claim.data.componentId}`}>← back to {componentName}</a>
		</nav>

		<header class="claim-header">
			<p class="claim-kicker">Development note · {componentName}</p>
			<h1>{claim.data.claim}</h1>
			<p class="claim-author">
				by {claim.data.author} · {formatDate(claim.data.date)}
			</p>
			<p>{claim.data.summary}</p>
		</header>

		<section class="claim-section">
			<h2>Metadata</h2>
			<ul class="meta-list">
				<li>
					<strong>Component:</strong>
					<a href={`/features/${claim.data.componentId}`}>{componentName}</a>
				</li>
				<li><strong>Status:</strong> {claim.data.status}</li>
				<li><strong>Confidence:</strong> {claim.data.confidence}</li>
				<li><strong>Evidence type:</strong> {claim.data.sourceType}</li>
				<li><strong>Scope:</strong> {claim.data.scope}</li>
				<li><strong>Author:</strong> {claim.data.author}</li>
				<li><strong>Date:</strong> {formatDate(claim.data.date)}</li>
				<li><strong>RCP version:</strong> {claim.data.rcpVersion}</li>
				<li><strong>Xcode build:</strong> {claim.data.xcodeBuild}</li>
			</ul>
		</section>

		<section class="claim-section">
			<h2>Reproduction</h2>
			<ol>
				{claim.data.reproSteps.map((step: string) => <li>{step}</li>)}
			</ol>
		</section>

		<section class="claim-section">
			<h2>Evidence</h2>
			<ul class="evidence-list">
				{
					claim.data.evidence.map(
						(item: {
							type: string;
							path: string;
							artifactLabel?: string;
							publicUrl?: string;
							note?: string;
						}) => (
							<li>
								<div>
									{item.publicUrl ? (
										<a href={item.publicUrl} target="_blank" rel="noopener noreferrer">
											<strong>{item.artifactLabel ?? item.type}</strong>
										</a>
									) : (
										<strong>{item.artifactLabel ?? item.type}</strong>
									)}
								</div>
								{!item.publicUrl && isAbsoluteLocalPath(item.path) ? (
									<div>
										<em>local-only evidence path (not publicly exposed)</em>
									</div>
								) : !item.publicUrl ? (
									<div>
										<code>{item.path}</code>
									</div>
								) : null}
								{item.note && <p>{item.note}</p>}
							</li>
						),
					)
				}
			</ul>
		</section>

		<section class="claim-section prose">
			<h2>Details</h2>
			<Content />
		</section>
	</article>
</Base>

<style>
	.claim-page {
		max-width: 760px;
		margin: 0 auto;
		padding: 2rem 1.5rem 5rem;
	}

	.claim-breadcrumb a {
		color: var(--muted);
		text-decoration: none;
	}

	.claim-breadcrumb a:hover {
		color: var(--text);
		text-decoration: underline;
	}

	.claim-header h1 {
		font-size: clamp(1.4rem, 3vw, 1.9rem);
		line-height: 1.2;
		margin-top: 0.55rem;
	}

	.claim-header p {
		color: var(--muted);
		margin-top: 0.6rem;
	}

	.claim-kicker {
		font-size: 0.8rem;
		letter-spacing: 0.04em;
		color: var(--muted);
		text-transform: uppercase;
	}

	.claim-author {
		font-size: 0.875rem;
		margin-top: 0.5rem;
	}

	.claim-section {
		margin-top: 1.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}

	.claim-section h2 {
		font-size: 0.95rem;
		letter-spacing: 0.04em;
		color: var(--muted);
		margin-bottom: 0.7rem;
	}

	.meta-list,
	.evidence-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.evidence-list code,
	.meta-list code {
		overflow-wrap: anywhere;
	}

	.evidence-list a {
		color: var(--ios);
		text-decoration: none;
	}

	.evidence-list a:hover {
		text-decoration: underline;
	}

	.prose :global(p) {
		color: var(--text);
		line-height: 1.7;
		margin-bottom: 1rem;
	}

	.prose :global(p):last-child {
		margin-bottom: 0;
	}

	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		color: var(--text);
		margin-top: 2rem;
		margin-bottom: 1rem;
		line-height: 1.3;
	}

	.prose :global(h2) {
		font-size: 1.15rem;
		font-weight: 600;
	}

	.prose :global(h3) {
		font-size: 1rem;
		font-weight: 600;
	}

	.prose :global(h4) {
		font-size: 0.95rem;
		font-weight: 600;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1.25rem;
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		color: var(--text);
		line-height: 1.7;
		margin-bottom: 0.5rem;
	}

	.prose :global(li):last-child {
		margin-bottom: 0;
	}

	.prose :global(blockquote) {
		border-left: 3px solid var(--border);
		padding-left: 1rem;
		margin: 1.5rem 0;
		color: var(--muted);
		font-style: italic;
	}

	.prose :global(blockquote p) {
		margin-bottom: 0.75rem;
	}

	.prose :global(blockquote p):last-child {
		margin-bottom: 0;
	}

	.prose :global(pre) {
		margin: 1.5rem 0;
		padding: 1rem;
		background: var(--surface-up);
		border-radius: 8px;
		overflow-x: auto;
	}

	.prose :global(pre code) {
		font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
		font-size: 0.85rem;
		line-height: 1.6;
		background: none;
		padding: 0;
	}

	.prose :global(code) {
		font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
		font-size: 0.85em;
		background: var(--surface-up);
		padding: 0.15rem 0.35rem;
		border-radius: 4px;
	}

	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1.5rem 0;
		font-size: 0.9rem;
	}

	.prose :global(th),
	.prose :global(td) {
		border: 1px solid var(--border);
		padding: 0.5rem 0.75rem;
		text-align: left;
	}

	.prose :global(th) {
		background: var(--surface-up);
		font-weight: 600;
		font-size: 0.8rem;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}

	.prose :global(tr:nth-child(even)) {
		background: var(--surface);
	}

	.prose :global(tr:hover) {
		background: var(--surface-up);
	}
</style>
